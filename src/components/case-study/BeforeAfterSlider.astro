---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  beforeSrc: ImageMetadata | string;
  afterSrc: ImageMetadata | string;
  beforeAlt: string;
  afterAlt: string;
  beforeLabel?: string;
  afterLabel?: string;
  sliderLabel?: string;
  caption?: string;
  initialPosition?: number;
  loading?: 'lazy' | 'eager';
}

const {
  beforeSrc,
  afterSrc,
  beforeAlt,
  afterAlt,
  beforeLabel = 'Before',
  afterLabel = 'After',
  sliderLabel = 'Compare before and after website versions',
  caption,
  initialPosition = 50,
  loading = 'lazy',
} = Astro.props;

const clampedInitial = Math.max(0, Math.min(100, initialPosition));
const isBeforeExternal = typeof beforeSrc === 'string';
const isAfterExternal = typeof afterSrc === 'string';
const getImageAspectRatio = (source: ImageMetadata | string) =>
  typeof source === 'string' ? undefined : source.width / source.height;
const knownAspectRatios = [getImageAspectRatio(beforeSrc), getImageAspectRatio(afterSrc)].filter(
  (ratio): ratio is number => typeof ratio === 'number' && Number.isFinite(ratio) && ratio > 0
);
const frameAspectRatio = knownAspectRatios.length > 0 ? Math.max(...knownAspectRatios) : 16 / 10;
---

<figure class="before-after" data-before-after>
  <div
    class="before-after__viewport"
    data-before-after-viewport
    style={`--before-after-position: ${clampedInitial}%; --before-after-aspect-ratio: ${frameAspectRatio.toFixed(6)} / 1`}
  >
    {
      isBeforeExternal ? (
        <img
          class="before-after__image"
          src={beforeSrc as string}
          alt={beforeAlt}
          loading={loading}
          decoding="async"
        />
      ) : (
        <Image
          class="before-after__image"
          src={beforeSrc as ImageMetadata}
          alt={beforeAlt}
          loading={loading}
        />
      )
    }

    <div class="before-after__after-layer" aria-hidden="true">
      {
        isAfterExternal ? (
          <img
            class="before-after__image"
            src={afterSrc as string}
            alt={afterAlt}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <Image
            class="before-after__image"
            src={afterSrc as ImageMetadata}
            alt={afterAlt}
            loading="lazy"
          />
        )
      }
    </div>

    <div class="before-after__divider" data-before-after-divider>
      <span class="before-after__handle" aria-hidden="true">
        <span class="before-after__handle-grip"></span>
      </span>
    </div>

    <span class="before-after__badge before-after__badge--before">{beforeLabel}</span>
    <span class="before-after__badge before-after__badge--after">{afterLabel}</span>

    <input
      class="before-after__range"
      type="range"
      min="0"
      max="100"
      step="1"
      value={clampedInitial}
      aria-label={sliderLabel}
      data-before-after-input
    />
  </div>

  {caption && <figcaption class="before-after__caption">{caption}</figcaption>}
</figure>

<style>
  .before-after {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .before-after__viewport {
    position: relative;
    overflow: hidden;
    aspect-ratio: var(--before-after-aspect-ratio);
    border: var(--surface-border);
    border-radius: var(--radius-card);
    background: var(--color-bg-surface);
  }

  .before-after__image {
    display: block;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .before-after__after-layer {
    position: absolute;
    inset: 0;
    overflow: hidden;
    clip-path: inset(0 0 0 var(--before-after-position));
  }

  .before-after__divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--before-after-position);
    width: 1px;
    background: color-mix(in srgb, var(--color-bg-surface) 86%, var(--color-brand));
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-brand) 22%, transparent),
      0 0 18px color-mix(in srgb, var(--color-bg) 36%, transparent);
    transform: translateX(-0.5px);
    z-index: 2;
    cursor: ew-resize;
    touch-action: none;
  }

  .before-after__handle {
    position: absolute;
    top: 50%;
    left: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid color-mix(in srgb, var(--color-border) 78%, var(--color-bg-surface));
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-bg-surface) 92%, transparent);
    color: var(--color-text-secondary);
    box-shadow:
      0 0.75rem 1.75rem color-mix(in srgb, var(--color-text) 18%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 60%, transparent);
    transform: translate(-50%, -50%);
    backdrop-filter: blur(14px) saturate(1.15);
    -webkit-backdrop-filter: blur(14px) saturate(1.15);
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .before-after__handle::before,
  .before-after__handle::after {
    content: '';
    width: 0.45rem;
    height: 0.45rem;
    border-top: 2px solid currentColor;
    border-left: 2px solid currentColor;
  }

  .before-after__handle::before {
    transform: rotate(-45deg);
  }

  .before-after__handle::after {
    transform: rotate(135deg);
  }

  .before-after__handle-grip {
    width: 1px;
    height: 1rem;
    border-radius: 9999px;
    background: color-mix(in srgb, currentColor 42%, transparent);
  }

  .before-after__range {
    position: absolute;
    inset: 0;
    width: calc(100% + 2.75rem);
    height: 100%;
    left: -1.375rem;
    margin: 0;
    appearance: none;
    background: transparent;
    cursor: ew-resize;
    z-index: 10;
  }

  .before-after__range:focus {
    outline: none;
  }

  /* Webkit thumb */
  .before-after__range::-webkit-slider-thumb {
    appearance: none;
    width: 2.75rem;
    height: 2.75rem;
    border: 0;
    border-radius: 9999px;
    background: transparent;
    box-shadow: none;
    cursor: ew-resize;
    transition: transform 0.1s ease;
  }

  .before-after__range:active::-webkit-slider-thumb {
    transform: scale(1.06);
  }

  /* Firefox thumb */
  .before-after__range::-moz-range-thumb {
    width: 2.75rem;
    height: 2.75rem;
    border: 0;
    border-radius: 9999px;
    background: transparent;
    box-shadow: none;
    cursor: ew-resize;
    transition: transform 0.1s ease;
  }

  .before-after__range:active::-moz-range-thumb {
    transform: scale(1.06);
  }

  /* Focus styles */
  .before-after__viewport:has(.before-after__range:focus-visible) .before-after__handle {
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  .before-after__viewport:has(.before-after__range:active) .before-after__handle {
    border-color: color-mix(in srgb, var(--color-brand) 50%, var(--color-border));
    box-shadow:
      0 0.85rem 2rem color-mix(in srgb, var(--color-text) 22%, transparent),
      0 0 0 0.25rem color-mix(in srgb, var(--color-brand) 12%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 60%, transparent);
    transform: translate(-50%, -50%) scale(1.04);
  }

  /* Hide track */
  .before-after__range::-webkit-slider-runnable-track {
    background: transparent;
    border: none;
  }

  .before-after__range::-moz-range-track {
    background: transparent;
    border: none;
  }

  .before-after__caption {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.4;
  }
  .before-after__badge {
    position: absolute;
    top: 0.75rem;
    z-index: 1;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-bg-surface) 88%, transparent);
    color: var(--color-text-strong);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.4rem 0.65rem;
  }

  .before-after__badge--before {
    left: 0.75rem;
  }

  .before-after__badge--after {
    right: 0.75rem;
  }
</style>

<script>
  const sliders = document.querySelectorAll('[data-before-after]');

  for (const slider of sliders) {
    const viewport = slider.querySelector('[data-before-after-viewport]');
    const input = slider.querySelector('[data-before-after-input]');

    if (!(viewport instanceof HTMLElement) || !(input instanceof HTMLInputElement)) {
      continue;
    }

    const syncSliderPosition = () => {
      viewport.style.setProperty('--before-after-position', `${input.value}%`);
    };

    // Native range handles keyboard and thumb drag.
    // We add a pointer listener to the viewport to allow "drag anywhere" UX.
    const setFromClientX = (clientX: number) => {
      const bounds = viewport.getBoundingClientRect();
      if (!bounds.width) return;
      const percent = ((clientX - bounds.left) / bounds.width) * 100;
      input.value = String(Math.round(Math.max(0, Math.min(100, percent))));
      syncSliderPosition();
    };

    let isDragging = false;

    const onPointerDown = (event: PointerEvent) => {
      if (event.button !== 0) return; // Only left click
      isDragging = true;
      setFromClientX(event.clientX);
      if (event.target instanceof HTMLElement) {
        event.target.setPointerCapture(event.pointerId);
      }
    };

    const onPointerMove = (event: PointerEvent) => {
      if (!isDragging) return;
      setFromClientX(event.clientX);
    };

    const onPointerUp = (event: PointerEvent) => {
      isDragging = false;
      if (event.target instanceof HTMLElement && event.target.hasPointerCapture(event.pointerId)) {
        event.target.releasePointerCapture(event.pointerId);
      }
    };

    input.addEventListener('input', syncSliderPosition);
    input.addEventListener('pointerdown', onPointerDown);
    input.addEventListener('pointermove', onPointerMove);
    input.addEventListener('pointerup', onPointerUp);
    input.addEventListener('pointercancel', onPointerUp);

    syncSliderPosition();
  }
</script>
