---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  class="overflow-hidden rounded-2xl border border-(--color-border) bg-(--color-bg-surface) px-4 py-5 shadow-sm sm:px-5"
>
  <div class="flex flex-col gap-4">
    <header class="flex flex-col gap-3 border-b border-(--color-border) pb-4">
      <h2>{t('home.contactTitle')}</h2>
      <p class="home-body-text">{t('home.contact')}</p>
    </header>
    <div class="flex flex-wrap items-center gap-6 pt-1">
      <a
        href="mailto:anna@zezulka.me"
        class="inline-flex rounded-full border-2 border-(--color-brand) px-6 py-3 font-medium text-(--color-brand) transition-colors hover:bg-(--color-brand) hover:text-(--color-bg)"
      >
        {t('home.contactCta')}
      </a>
      <div class="home-social-links flex items-center gap-4">
        <a
          href="https://www.linkedin.com/in/anna-zezulka-8956b9384"
          target="_blank"
          rel="me noopener noreferrer"
          aria-label={t('home.social.linkedin')}
        >
          <Icon name="lucide:linkedin" class="size-6" />
        </a>
        <a
          href="https://signal.me/#eu/9qRmDm7yUKwySQZKonrkTt3YjPXONZKdBY8K-IB_rE6Fhuo0bbROi7IKN-l2C1Ky"
          target="_blank"
          rel="me noopener noreferrer"
          aria-label={t('home.social.signal')}
        >
          <Icon name="lucide:message-circle-dashed" class="size-6" />
        </a>
      </div>
    </div>
  </div>
</section>
