---
import { Image } from 'astro:assets';
import avatar from '../../assets/avatar.png';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';
import { identity } from '../../data/identity';
import { toSafeExternalUrl } from '../../security/external-links';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const siteName = t('site.name');
const keyoxideUrl = toSafeExternalUrl(identity.keyoxide);
---

<div class="flex flex-col gap-8">
  <header class="flex flex-col gap-6 sm:flex-row sm:items-center">
    <Image
      src={avatar}
      alt={siteName}
      width={128}
      height={128}
      loading="eager"
      fetchpriority="high"
      class="size-24 shrink-0 rounded-full border border-(--color-border) object-cover sm:size-32"
    />
    <div class="flex flex-col gap-2 sm:gap-4">
      <div class="flex items-center gap-1.75">
        <h1>{siteName}</h1>
        {
          keyoxideUrl && (
            <a
              href={keyoxideUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="home-social-links translate-y-0.5"
              aria-label={t('home.social.keyoxide')}
              title={t('home.social.keyoxide')}
            >
              <Icon
                name="lucide:shield-check"
                class="size-6 text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
              />
            </a>
          )
        }
      </div>
      <p class="home-body-text">
        {t('role.title')}
      </p>
    </div>
  </header>
</div>
