---
import { Image } from 'astro:assets';
import avatar from '../../assets/avatar.png';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const siteName = t('site.name');
---

<div class="flex flex-col gap-8">
  <header class="flex flex-col gap-6 sm:flex-row sm:items-center">
    <Image
      src={avatar}
      alt={siteName}
      width={128}
      height={128}
      loading="eager"
      fetchpriority="high"
      class="size-24 shrink-0 rounded-full border border-(--color-border) object-cover sm:size-32"
    />
    <div class="flex flex-col gap-2 sm:gap-4">
      <h1>{siteName}</h1>
      <p class="home-body-text">
        {t('role.title')}
      </p>
      <div class="home-social-links flex items-center gap-4">
        <a
          href="https://www.linkedin.com/in/anna-zezulka/"
          target="_blank"
          rel="me noopener noreferrer"
          aria-label="LinkedIn"
        >
          <Icon name="lucide:linkedin" class="size-5" />
        </a>
        <a
          href="https://orcid.org/0009-0005-7350-5354"
          target="_blank"
          rel="me noopener noreferrer"
          aria-label="ORCID"
        >
          <Icon name="simple-icons:orcid" class="size-5" />
        </a>
        <a
          href="https://github.com/annazez"
          target="_blank"
          rel="me noopener noreferrer"
          aria-label="Github"
        >
          <Icon name="simple-icons:github" class="size-5" />
        </a>
        <a
          href="https://codeberg.org/annazez"
          target="_blank"
          rel="me noopener noreferrer"
          aria-label="Codeberg"
        >
          <Icon name="simple-icons:codeberg" class="size-5" />
        </a>
      </div>
    </div>
  </header>
  <section class="home-body-text flex flex-col gap-4">
    <p>{t('hero.manifesto')}</p>
  </section>

  <!-- Social links and contact moved to the bottom of the page -->
</div>
