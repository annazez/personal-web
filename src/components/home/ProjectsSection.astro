---
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projectArticles: CollectionEntry<'projects'>[];
}

interface Project {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  repo?: string;
  website?: string;
}

const { projectArticles } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projectsHref = `/${lang}/projects/`;
const moreLabel = t('projects.more');
const articleBySlug = new Map(projectArticles.map(article => [article.data.slug, article.data]));

const projects: Project[] = [
  {
    slug: 'telperion',
    title: 'Telperion',
    description: t('projects.telperion.description'),
    tags: ['Astro', 'i18n', 'SSG', 'WCAG', 'Jamstack'],
    website: 'https://telperion.cz',
    repo: 'https://github.com/annazez/telperion-web',
  },
  {
    slug: 'mental-health-app',
    title: 'Mental Health App',
    description: t('projects.mentalHealth.description'),
    tags: ['Architecture', 'Mobile', 'Healthcare', 'WIP'],
  },
];
---

<project-carousel class="flex flex-col gap-6">
  <header class="flex flex-col gap-2">
    <h2 class="home-section-title flex items-baseline justify-between gap-4 font-medium">
      <span>{t('projects.title')}</span>
      <a href={projectsHref} class="home-section-more-link">
        {moreLabel}
      </a>
    </h2>
    <p class="home-body-text">
      {t('projects.subtitle')}
    </p>
  </header>

  <div class="group relative">
    <div
      class="projects-track flex w-full snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-2 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      {
        projects.map(project => {
          const article = articleBySlug.get(project.slug);

          return (
            <div class="w-full flex-none shrink-0 snap-center">
              <div class="h-full">
                <ProjectCard
                  title={article?.title ?? project.title}
                  description={project.description}
                  articleSlug={
                    project.slug === 'telperion' ? (article?.slug ?? project.slug) : undefined
                  }
                  tags={article?.tags ?? project.tags}
                  repo={project.repo}
                  website={project.website}
                />
              </div>
            </div>
          );
        })
      }
    </div>

    <div class="mt-2 flex items-center justify-between px-2">
      <button
        class="nav-btn prev p-2 text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-brand)] disabled:opacity-30 disabled:hover:text-[var(--color-text-muted)]"
        aria-label="Previous project"
      >
        <Icon name="lucide:arrow-left" class="size-5 sm:size-6" />
      </button>
      <div class="dots flex flex-1 justify-center gap-2">
        {
          projects.map((_, i) => (
            <button
              aria-label={`Go to slide ${i + 1}`}
              class="dot size-2.5 rounded-full bg-[var(--color-border)] transition-colors data-[active=true]:bg-[var(--color-brand)]"
            />
          ))
        }
      </div>
      <button
        class="nav-btn next p-2 text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-brand)] disabled:opacity-30 disabled:hover:text-[var(--color-text-muted)]"
        aria-label="Next project"
      >
        <Icon name="lucide:arrow-right" class="size-5 sm:size-6" />
      </button>
    </div>
  </div>
</project-carousel>

<script>
  class ProjectCarousel extends HTMLElement {
    #track: HTMLElement | null = null;
    #prevBtn: HTMLButtonElement | null = null;
    #nextBtn: HTMLButtonElement | null = null;
    #dots!: NodeListOf<HTMLButtonElement>;
    #cleanup?: () => void;

    connectedCallback() {
      this.#cleanup?.();

      this.#track = this.querySelector<HTMLElement>('.projects-track');
      this.#prevBtn = this.querySelector<HTMLButtonElement>('.prev');
      this.#nextBtn = this.querySelector<HTMLButtonElement>('.next');
      this.#dots = this.querySelectorAll<HTMLButtonElement>('.dot');

      if (!this.#track || !this.#prevBtn || !this.#nextBtn || !this.#dots.length) return;

      const cleanupControls = this.#bindControls();

      setTimeout(() => this.#updateState(), 50);

      const onResize = () => this.#updateState();
      window.addEventListener('resize', onResize);
      this.#cleanup = () => {
        window.removeEventListener('resize', onResize);
        cleanupControls();
      };
    }

    disconnectedCallback() {
      this.#cleanup?.();
      this.#cleanup = undefined;
    }

    #updateState = () => {
      if (!this.#track || !this.#prevBtn || !this.#nextBtn) return;

      const scrollLeft = this.#track.scrollLeft;
      const width = this.#track.clientWidth;
      if (width === 0) return;
      const index = Math.round(scrollLeft / width);

      this.#prevBtn.disabled = index === 0;
      this.#nextBtn.disabled = index === this.#dots.length - 1;

      this.#dots.forEach((dot, i) => {
        if (i === index) {
          dot.setAttribute('data-active', 'true');
        } else {
          dot.removeAttribute('data-active');
        }
      });
    };

    #bindControls(): () => void {
      const track = this.#track!;
      const prevBtn = this.#prevBtn!;
      const nextBtn = this.#nextBtn!;

      const onScroll = () => requestAnimationFrame(this.#updateState);
      const onPrev = () => track.scrollBy({ left: -track.clientWidth, behavior: 'smooth' });
      const onNext = () => track.scrollBy({ left: track.clientWidth, behavior: 'smooth' });

      track.addEventListener('scroll', onScroll);
      prevBtn.addEventListener('click', onPrev);
      nextBtn.addEventListener('click', onNext);

      const dotCleanups = Array.from(this.#dots).map((dot, i) => {
        const onClick = () => track.scrollTo({ left: track.clientWidth * i, behavior: 'smooth' });
        dot.addEventListener('click', onClick);
        return () => dot.removeEventListener('click', onClick);
      });

      return () => {
        track.removeEventListener('scroll', onScroll);
        prevBtn.removeEventListener('click', onPrev);
        nextBtn.removeEventListener('click', onNext);
        dotCleanups.forEach(fn => fn());
      };
    }
  }

  if (!customElements.get('project-carousel')) {
    customElements.define('project-carousel', ProjectCarousel);
  }
</script>
