---
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';
import { defaultLang, type LanguageCode } from '../../i18n/dictionary';

interface Props {
  lang?: LanguageCode;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="flex w-full flex-wrap items-center gap-x-6 gap-y-3 border-t border-zinc-200 pt-8 dark:border-zinc-800">
  <div class="flex items-center gap-6">
    <a
      href="https://github.com/annazez"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="text-zinc-400 transition-colors hover:text-zinc-900 dark:hover:text-zinc-100"
      ><Icon name="lucide:github" class="h-5 w-5" /></a
    >
    <a
      href="mailto:anna.zezulka@proton.me"
      aria-label="Email"
      class="text-zinc-400 transition-colors hover:text-zinc-900 dark:hover:text-zinc-100"
      ><Icon name="lucide:mail" class="h-5 w-5" /></a
    >
    <a
      href="/humans.txt"
      aria-label="Humans.txt"
      class="text-zinc-400 transition-colors hover:text-zinc-900 dark:hover:text-zinc-100"
      ><Icon name="lucide:file-text" class="h-5 w-5" /></a
    >
    <a
      href="/pgp/public-key.asc"
      aria-label="PGP public key"
      class="text-zinc-400 transition-colors hover:text-zinc-900 dark:hover:text-zinc-100"
      ><Icon name="lucide:key-round" class="h-5 w-5" /></a
    >
  </div>

  <p class="w-full text-xs text-zinc-500 dark:text-zinc-400 sm:ml-auto sm:w-auto sm:text-right">
    <span>{t('footer.carbonFootprint')}</span>
    <span id="carbon-footprint-value" data-loading={t('footer.loading')}> {t('footer.loading')}</span>
  </p>

  <script is:inline>
    (() => {
      const valueElement = document.getElementById('carbon-footprint-value');
      if (!valueElement) return;

      const loadingText = valueElement.getAttribute('data-loading') || '...';

      const updateCarbonFootprint = () => {
        const navigationEntry = performance.getEntriesByType('navigation')[0];
        const resources = performance.getEntriesByType('resource');

        const navigationTransfer =
          navigationEntry && 'transferSize' in navigationEntry ? navigationEntry.transferSize : 0;

        const totalTransferSize = resources.reduce((sum, entry) => {
          if ('transferSize' in entry) return sum + entry.transferSize;
          return sum;
        }, navigationTransfer);

        if (!Number.isFinite(totalTransferSize) || totalTransferSize <= 0) {
          valueElement.textContent = loadingText;
          return;
        }

        // Approximation based on common web carbon models.
        const gramsCo2 = totalTransferSize * 4.8e-10;
        valueElement.textContent = `${gramsCo2.toFixed(4)} g CO2e`;
      };

      if (document.readyState === 'complete') {
        updateCarbonFootprint();
      } else {
        window.addEventListener('load', updateCarbonFootprint, { once: true });
      }
    })();
  </script>
</footer>
