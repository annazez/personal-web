---
import NavLinks from './NavLinks.astro';
import LanguagePicker from './LanguagePicker.astro';
import ThemeToggle from './ThemeToggle.astro';
import MobileMenuToggle from './MobileMenuToggle.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang);
---

<header
  data-header-nav
  class="z-50 mx-auto w-full max-w-2xl px-6 pt-4 md:absolute md:top-3 md:left-1/2 md:mx-0 md:-translate-x-1/2 md:pt-0"
>
  <div class="relative flex flex-col gap-2">
    <MobileMenuToggle />

    <nav
      id="header-nav-panel"
      aria-label={t('ui.mobileNavigationLabel')}
      class="nav-panel flex flex-col items-stretch gap-2 md:flex-row md:items-center md:justify-between md:gap-4"
    >
      <div class="nav-panel__links">
        <NavLinks />
      </div>

      <div class="nav-panel__controls flex flex-col items-stretch gap-2 md:flex-row md:gap-1.5">
        <LanguagePicker />
        <ThemeToggle
          className="min-h-11 w-full justify-between rounded-lg border border-(--color-border) bg-(--color-bg) text-(--color-text-muted) transition-colors duration-200 group-open:text-(--color-brand) hover:border-(--color-text-muted) hover:text-(--color-brand) md:min-h-9 md:w-auto md:min-w-[6.75rem] md:px-2.5"
        />
      </div>
    </nav>
  </div>
</header>

<style>
  /* Mobile visibility via :has() */
  .nav-panel {
    display: flex;
    border: 0 solid transparent;
    border-radius: 0.75rem;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    padding: 0;
    pointer-events: none;
    transform: translateY(-0.35rem);
    transition:
      max-height 220ms ease,
      opacity 160ms ease,
      transform 220ms ease,
      padding 220ms ease,
      border-width 220ms ease,
      border-color 220ms ease,
      background-color 220ms ease;
  }

  :global([data-header-nav]:has([data-mobile-menu-toggle][open])) .nav-panel {
    border-width: 1px;
    border-color: var(--color-border);
    background-color: color-mix(in srgb, var(--color-bg) 94%, transparent);
    max-height: 40rem;
    opacity: 1;
    overflow: visible;
    padding: 0.5rem;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* Desktop visibility */
  @media (min-width: 48rem) {
    :global(#page-shell > main) {
      padding-top: 5.875rem;
    }

    .nav-panel {
      border-width: 1px;
      border-color: var(--color-border);
      background-color: color-mix(in srgb, var(--color-bg) 94%, transparent);
      max-height: none;
      opacity: 1;
      overflow: visible;
      padding: 0.375rem;
      pointer-events: auto;
      transform: none;
      transition: none;
    }
  }
</style>
