---
import { Icon } from 'astro-icon/components';
---

<button
  id="theme-toggle"
  aria-label="Toggle dark mode"
  class="rounded-lg p-2 text-zinc-400 transition-colors hover:text-zinc-900 dark:text-zinc-500 dark:hover:text-zinc-100"
>
  <Icon name="lucide:sun" class="h-5 w-5" id="sun-icon" />
  <Icon name="lucide:moon" class="hidden h-5 w-5" id="moon-icon" />
</button>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const sunIcon = document.getElementById('sun-icon');
  const moonIcon = document.getElementById('moon-icon');
  let isThemeTransitionRunning = false;

  function createThemeOverlay(nextTheme: 'light' | 'dark') {
    const overlay = document.createElement('div');
    overlay.className = 'theme-transition-overlay';
    overlay.dataset.theme = nextTheme;

    document.body.appendChild(overlay);
    return overlay;
  }

  function waitForAnimation(animation: Animation) {
    return new Promise<void>(resolve => {
      animation.addEventListener('finish', () => resolve(), { once: true });
    });
  }

  // Check for saved theme preference or default to light mode
  const savedTheme = localStorage.getItem('theme');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const initialTheme = savedTheme || (prefersDark ? 'dark' : 'light');

  // Apply theme and optionally animate transition
  function applyTheme(theme: 'light' | 'dark') {
    const html = document.documentElement;
    if (theme === 'dark') {
      html.classList.add('dark');
      html.style.colorScheme = 'dark';
      sunIcon?.classList.add('hidden');
      moonIcon?.classList.remove('hidden');
    } else {
      html.classList.remove('dark');
      html.style.colorScheme = 'light';
      sunIcon?.classList.remove('hidden');
      moonIcon?.classList.add('hidden');
    }
  }

  async function transitionTheme(theme: 'light' | 'dark', options: { animate?: boolean } = {}) {
    if (!options.animate) {
      applyTheme(theme);
      return;
    }

    if (isThemeTransitionRunning) {
      applyTheme(theme);
      return;
    }

    isThemeTransitionRunning = true;
    const html = document.documentElement;
    html.classList.add('theme-switching');

    try {
      // Create overlay at full opacity BEFORE applying theme
      const overlay = createThemeOverlay(theme);
      overlay.style.opacity = '1';
      
      // Force synchronous layout to ensure overlay is rendered before theme change
      void overlay.offsetHeight;
      
      // Now apply theme while overlay covers the screen
      applyTheme(theme);

      const fadeOut = overlay.animate([{ opacity: 1 }, { opacity: 0 }], {
        duration: 150,
        easing: 'cubic-bezier(0.4, 0, 0.2, 1)',
        fill: 'forwards',
      });

      await waitForAnimation(fadeOut);
      overlay.remove();
    } finally {
      html.classList.remove('theme-switching');
      isThemeTransitionRunning = false;
    }
  }

  applyTheme(initialTheme as 'light' | 'dark');

  // Handle theme toggle
  themeToggle?.addEventListener('click', async () => {
    const html = document.documentElement;
    const newTheme = (html.classList.contains('dark') ? 'light' : 'dark') as 'light' | 'dark';
    await transitionTheme(newTheme, { animate: true });
    localStorage.setItem('theme', newTheme);
  });

  // Listen for system theme changes
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', async e => {
    const newTheme = (e.matches ? 'dark' : 'light') as 'light' | 'dark';
    localStorage.removeItem('theme'); // Clear saved preference to follow system
    await transitionTheme(newTheme, { animate: true });
  });

  // Keep theme in sync across tabs/windows and animate there too
  window.addEventListener('storage', async e => {
    if (e.key !== 'theme') {
      return;
    }

    const prefersDarkNow = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const syncedTheme = (e.newValue || (prefersDarkNow ? 'dark' : 'light')) as 'light' | 'dark';
    await transitionTheme(syncedTheme, { animate: true });
  });
</script>
