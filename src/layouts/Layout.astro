---
import { SEO } from 'astro-seo';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import { languages } from '../i18n/dictionary';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Anna Zezulka', lang = 'en' } = Astro.props;

const langKeys = Object.keys(languages).join('|');
const langRegex = new RegExp(`^/(${langKeys})`);
const pathname = Astro.url.pathname;
const pathWithoutLang = pathname.replace(langRegex, '');
const siteUrl = Astro.site ?? Astro.url;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self';"
    />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
        document.documentElement.style.colorScheme = 'dark';
      } else {
        document.documentElement.classList.remove('dark');
        document.documentElement.style.colorScheme = 'light';
      }
    </script>
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: '/og-image.jpg',
        },
      }}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {
      Object.keys(languages).map(l => (
        <link rel="alternate" hreflang={l} href={new URL(`/${l}${pathWithoutLang}`, siteUrl)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
  </head>
  <body>
    <div id="arch" style="display: none;" aria-hidden="true"></div>
    <div id="audit" style="display: none;" aria-hidden="true"></div>
    <div id="layers" style="display: none;" aria-hidden="true"></div>
    <div id="page-shell">
      <a href="#main-content" class="skip-link">Skip to main content</a>
      <slot />
    </div>
    <script is:inline>
      (() => {
        const pageShell = document.getElementById('page-shell');
        if (!pageShell) return;

        const defaults = {
          rotateX: 60,
          rotateZ: -30,
          scale: 0.8,
        };

        const state = {
          ...defaults,
          isDragging: false,
          dragStartX: 0,
          dragStartY: 0,
          dragStartRotateX: defaults.rotateX,
          dragStartRotateZ: defaults.rotateZ,
          suppressClick: false,
        };

        const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

        const isLayersActive = () => window.location.hash === '#layers';

        const applyLayersTransform = () => {
          pageShell.style.setProperty('--layers-rotate-x', `${state.rotateX}deg`);
          pageShell.style.setProperty('--layers-rotate-z', `${state.rotateZ}deg`);
          pageShell.style.setProperty('--layers-scale', String(state.scale));
        };

        const resetLayersTransform = () => {
          pageShell.style.removeProperty('--layers-rotate-x');
          pageShell.style.removeProperty('--layers-rotate-z');
          pageShell.style.removeProperty('--layers-scale');
        };

        const syncLayersMode = () => {
          if (isLayersActive()) {
            state.rotateX = defaults.rotateX;
            state.rotateZ = defaults.rotateZ;
            state.scale = defaults.scale;
            applyLayersTransform();
            pageShell.classList.add('layers-mode-active');
            return;
          }

          state.isDragging = false;
          state.suppressClick = false;
          pageShell.classList.remove('layers-mode-active', 'layers-dragging');
          resetLayersTransform();
        };

        const finishDrag = () => {
          if (!state.isDragging) return;
          state.isDragging = false;
          pageShell.classList.remove('layers-dragging');
          state.suppressClick = true;
          window.setTimeout(() => {
            state.suppressClick = false;
          }, 0);
        };

        pageShell.addEventListener('pointerdown', event => {
          if (!isLayersActive() || event.button !== 0) return;

          state.isDragging = true;
          state.dragStartX = event.clientX;
          state.dragStartY = event.clientY;
          state.dragStartRotateX = state.rotateX;
          state.dragStartRotateZ = state.rotateZ;
          pageShell.classList.add('layers-dragging');

          if (pageShell.setPointerCapture) {
            pageShell.setPointerCapture(event.pointerId);
          }
        });

        pageShell.addEventListener('pointermove', event => {
          if (!state.isDragging || !isLayersActive()) return;

          const deltaX = event.clientX - state.dragStartX;
          const deltaY = event.clientY - state.dragStartY;

          state.rotateZ = state.dragStartRotateZ + deltaX * 0.2;
          state.rotateX = clamp(state.dragStartRotateX + deltaY * 0.2, 20, 80);
          applyLayersTransform();
        });

        pageShell.addEventListener('pointerup', finishDrag);
        pageShell.addEventListener('pointercancel', finishDrag);
        pageShell.addEventListener('lostpointercapture', finishDrag);

        pageShell.addEventListener(
          'wheel',
          event => {
            if (!isLayersActive()) return;

            event.preventDefault();
            const zoomFactor = Math.exp(-event.deltaY * 0.001);
            state.scale = clamp(state.scale * zoomFactor, 0.45, 1.4);
            applyLayersTransform();
          },
          { passive: false }
        );

        pageShell.addEventListener(
          'click',
          event => {
            if (!state.suppressClick) return;

            event.preventDefault();
            event.stopImmediatePropagation();
          },
          true
        );

        window.addEventListener('hashchange', syncLayersMode);
        syncLayersMode();
      })();
    </script>
  </body>
</html>
