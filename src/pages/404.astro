---
import Layout from '../layouts/Layout.astro';
import { dictionary } from '../i18n/dictionary';

const msg = dictionary.en['404.message'];
const returnBtn = dictionary.en['404.return'];
---

<Layout title="404 | Not Found">
  <main class="min-h-screen flex flex-col items-center justify-center text-center px-6">
    <h1 class="text-7xl font-bold text-zinc-900 tracking-tighter mb-4">404</h1>
    <p class="text-zinc-500 mb-8 font-mono text-sm tracking-wide">
      {msg}
    </p>
    <a 
      href="/" 
      class="px-6 py-2 border border-zinc-200 text-zinc-600 hover:text-zinc-900 hover:border-zinc-400 transition-colors font-mono text-xs tracking-widest uppercase"
    >
      {returnBtn}
    </a>
  </main>
</Layout>