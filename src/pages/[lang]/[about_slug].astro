---
import Layout from '../../layouts/Layout.astro';
import BackLink from '../../components/BackLink.astro';
import Footer from '../../components/ui/Footer.astro';
import LanguagePicker from '../../components/ui/LanguagePicker.astro';
import { getValidLanguageCode, supportedLangs, routes } from '../../i18n/dictionary';
import ContentCard from '../../components/home/ContentCard.astro';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return supportedLangs.map(lang => ({ params: { lang, about_slug: routes.about[lang] } }));
}

const currentLang = getValidLanguageCode(Astro.params.lang);
const t = useTranslations(currentLang);
---

<Layout title={t('about.title')} lang={currentLang}>
  <LanguagePicker />

  <main id="main-content" class="mx-auto flex max-w-2xl flex-col gap-8 px-6 py-16">
    <BackLink href={`/${currentLang}/`} />

    <header class="flex flex-col gap-4">
      <h1 class="home-display-title">{t('about.title')}</h1>
      <p class="home-body-text">{t('about.subtitle')}</p>
    </header>

    <section class="flex flex-col gap-8" aria-label={t('about.title')}>
      <section class="flex flex-col gap-3" aria-labelledby="about-who">
        <h2 id="about-who" class="home-section-title font-medium">{t('about.section.who')}</h2>
        <ul class="flex flex-col gap-4">
          <ContentCard
            title={t('about.card.psych.title')}
            description={t('about.card.psych.description')}
          />
        </ul>
      </section>

      <section class="flex flex-col gap-3" aria-labelledby="about-how">
        <h2 id="about-how" class="home-section-title font-medium">{t('about.section.how')}</h2>
        <ul class="flex flex-col gap-4">
          <ContentCard
            title={t('about.card.static.title')}
            description={t('about.card.static.description')}
          />
          <ContentCard
            title={t('about.card.contact.title')}
            description={t('about.card.contact.description')}
            link={t('about.contact')}
            linkHref={`mailto:${t('about.contact')}`}
          />
        </ul>
      </section>
    </section>

    <Footer lang={currentLang} />
  </main>
</Layout>
