---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/ui/Footer.astro';
import Surface from '../../components/ui/Surface.astro';
import { getValidLanguageCode, supportedLangs } from '../../i18n/dictionary';
import { useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { toSafeLinkHref } from '../../security/external-links';

export function getStaticPaths() {
  return supportedLangs.map(lang => ({ params: { lang } }));
}

const currentLang = getValidLanguageCode(Astro.params.lang);
const t = await useTranslations(currentLang);

const competences = (await getCollection('competences'))
  .filter(c => c.id.startsWith(`${currentLang}/`))
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title={t('seo.competences')} description={t('competences.subtitle')} lang={currentLang}>
  <main id="main-content" class="mx-auto flex max-w-2xl flex-col gap-8 px-6 py-16">
    <section class="flex flex-col gap-4">
      <h1>{t('competences.title')}</h1>
      <p class="home-body-text">{t('competences.subtitle')}</p>
    </section>

    <div class="flex flex-col gap-6">
      {
        competences.map(competence => (
          <Surface as="section" class="flex flex-col gap-3">
            <div class="flex items-center gap-3">
              <Icon name={competence.data.icon} class="h-6 w-6 text-(--color-brand)" />
              <h2>{competence.data.title}</h2>
            </div>
            <p class="home-body-text leading-relaxed">{competence.data.desc}</p>
            {competence.data.links?.map(link => {
              const safeHref = toSafeLinkHref(link.url);
              if (!safeHref) {
                return null;
              }

              const isExternal = safeHref.startsWith('https://');
              return (
                <Surface
                  as="a"
                  href={safeHref}
                  target={isExternal ? '_blank' : undefined}
                  rel={isExternal ? 'noopener noreferrer' : undefined}
                  class="group mt-2 flex items-center gap-4 bg-(--color-bg-surface-elevated) p-4 transition-colors hover:border-(--color-brand)"
                >
                  {link.image && (
                    <img
                      src={link.image}
                      alt={link.imageAlt || ''}
                      class="h-12 w-12 shrink-0 rounded-md bg-white object-contain p-1"
                    />
                  )}
                  <div class="flex flex-col">
                    <span class="font-medium text-(--color-text) transition-colors group-hover:text-(--color-brand)">
                      {link.title}
                    </span>
                    <span class="text-sm text-(--color-text-muted)">{link.subtitle}</span>
                  </div>
                </Surface>
              );
            })}
          </Surface>
        ))
      }
    </div>

    <Footer lang={currentLang} />
  </main>
</Layout>
