---
import Layout from '../layouts/Layout.astro';
import { defaultLang, languages } from '../i18n/dictionary';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(defaultLang);
const canonicalEn = new URL(`/${defaultLang}/`, Astro.site ?? Astro.url).toString();
const supportedLangs = Object.keys(languages); // ['en', 'cs']
const langEntries = Object.entries(languages);
---

<Layout title={t('seo.home')} lang={defaultLang} noIndex={true}>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0;url=/${defaultLang}/`} />
    <link rel="canonical" href={canonicalEn} />
  </Fragment>

  <main id="main-content" class="mx-auto flex max-w-2xl flex-col gap-4 px-6 py-16">
    <script is:inline define:vars={{ supportedLangs, defaultLang }}>
      const preferred =
        Array.isArray(navigator.languages) && navigator.languages.length
          ? navigator.languages[0]
          : navigator.language || defaultLang;

      const prefLangCode = preferred.split('-')[0].toLowerCase();

      const targetLang = supportedLangs.includes(prefLangCode) ? prefLangCode : defaultLang;
      window.location.replace(`/${targetLang}/`);
    </script>

    <noscript>
      <p class="home-body-text">Choose language:</p>
      <p class="home-body-text">
        {
          langEntries.map(([code, label], index) => (
            <>
              <a href={`/${code}/`}>{label}</a>
              {index < langEntries.length - 1 && ' | '}
            </>
          ))
        }
      </p>
    </noscript>
  </main>
</Layout>
